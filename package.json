{
  "name": "wwebjs-mcp-server",
  "version": "1.0.0",
  "description": "MCP server exposing the wwebjs-api (WhatsApp Web) REST API as MCP tools, generated dynamically from its OpenAPI/Swagger spec.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "wwebjs-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "fetch-swagger": "node scripts/fetch-swagger.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "undici": "^6.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
