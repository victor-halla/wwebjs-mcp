# ======================================================================
# wwebjs-mcp — configuration (copy to .env)
# ======================================================================

# --- Connection to the running wwebjs-api instance ---------------------
# Base URL of the wwebjs-api REST server this MCP server talks to.
# When both run in the same docker network, use the service name.
WWEBJS_API_URL=http://host.docker.internal:3000

# The API key configured on the wwebjs-api server (sent as x-api-key).
# Leave empty only if the wwebjs-api has no API_KEY set.
WWEBJS_API_KEY=changeme

# Per-request timeout in milliseconds.
WWEBJS_TIMEOUT_MS=60000

# --- MCP transport -----------------------------------------------------
# "http"  -> Streamable HTTP/SSE at http://<host>:<port>/mcp  (for containers)
# "stdio" -> classic stdio transport (run the process locally)
MCP_TRANSPORT=http
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8080

# Optional bearer token MCP clients must send as "Authorization: Bearer <token>"
# on the HTTP transport. Leave empty to disable.
# STRONGLY RECOMMENDED whenever the server is reachable outside localhost
# (e.g. exposed via Cloudflare Tunnel below) — without it, /mcp is open to
# anyone who can reach the URL. Generate one with: openssl rand -hex 32
MCP_AUTH_TOKEN=

# --- Remote HTTPS access (optional) -------------------------------------
# Token for the "cloudflared" service in docker-compose.yml, if you expose
# this server publicly via a Cloudflare Tunnel. Get it from the Cloudflare
# Zero Trust dashboard when creating the tunnel. Set MCP_AUTH_TOKEN above
# too — the tunnel makes /mcp reachable from the internet.
CLOUDFLARE_TUNNEL_TOKEN=

# --- Tool exposure (optional) -----------------------------------------
# Comma-separated allow-list; when set, ONLY these tools are exposed.
# Example: session_start,session_status,session_qr,client_sendMessage
MCP_TOOL_ALLOWLIST=

# Comma-separated deny-list applied after the allow-list. Use to hide
# destructive endpoints, e.g.:
MCP_TOOL_DENYLIST=session_terminateAll,session_terminateInactive

# --- Logging -----------------------------------------------------------
# debug | info | warn | error
LOG_LEVEL=info
